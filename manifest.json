{
  "manifest_version": 2,
  "name": "Kallang Booker",
  "version": "1.0.0",
  "description": "Auto-book badminton courts on thekallang.perfectgym.com",
  "icons": {
    "48": "icon-48.svg",
    "96": "icon-96.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://thekallang.perfectgym.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "*://thekallang.perfectgym.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "kallang-booker-f3a8c2d1@local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
